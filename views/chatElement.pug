html(lang="en")
    head
        link(rel="stylesheet", href="/style_login.css")
    body
        mixin chatCard(chat)
            .chat-card(data-id=chat.id)
                .chat-card-content
                    .chat-card-header
                        h3.chat-title= chat.name
                        span.chat-date= chat.date

                    .chat-meta
                        span.chat-owner Created by #{chat.owner}
                        span.chat-count #{chat.messages.length} messages

                button.chat-action(type="button")
                | Open