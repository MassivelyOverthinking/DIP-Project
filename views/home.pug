doctype html
html(lang="en")
    include templates/head.pug
    include templates/chatCard.pug
    +headpage('Home Page', '/style_homepage.css')
    body
        main.home-page
            section.home-card
                .home-header
                    h1 User: #{user.firstName} #{user.lastName}
                    p @#{user.username}

                if user.level === "3"
                    p.role-text You are an admin user.
                else if user.level === "2"
                    p.role-text You are a moderator user.
                else
                    p.role-text You are a regular user.

                .home-actions
                    if user.level !== "1"
                        a(href="/chat/create")
                            button.secondary-btn(type="button")
                                span.text Create Chatroom
                    if user.level === "3"
                        a(href="/user/admin")
                            button.secondary-btn(type="button")
                                span.text Manage
                    a(href="/user/logout")
                        button.secondary-btn(type="button")
                            span.text Log out

                .chat-section
                    h2 Your Chatrooms

                    if chats && chats.length > 0
                            each chat in chats
                                if chat.participant === user.id || chat.owner === user.id
                                    +chatCard(chat, user.level)
                                else if user.level === "3"
                                    +chatCard(chat, user.level)
                    else
                        .empty-state
                            p You are not part of any chatrooms yet.