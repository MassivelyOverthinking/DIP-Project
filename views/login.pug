doctype html
html(lang="en")
    include templates/head.pug
    include templates/formButton.pug
    +headpage('Login Page', '/style_login.css')
    body
        main.auth-page
            section.auth-card
                .auth-header
                    h1 Welcome back
                    p Sign in to continue

                form.auth-form(action="/user/login", method="post")
                    input(type="text", name="username", placeholder="Username", required)
                    input(type="password", name="password", placeholder="Password", required)

                    hr.separator
                    +form-button("Login")

                p.footer
                    | Don't have an account?
                    a(href="/user/register") Sign up here