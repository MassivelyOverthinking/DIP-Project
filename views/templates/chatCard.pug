mixin chatCard(chat, userLevel, userId)
    .chat-card(data-id=chat.id)
        .chat-card-content
            .chat-card-header
                h3.chat-title= chat.name
                span.chat-date= chat.date

            .chat-meta
                span.owner Created by #{chat.owner}
                span.count #{chat.messages ? chat.messages.length : 0} messages

        .chat-actions
            form(
                    action=`/chat/${chat.id}`, 
                    method="get"
                )
                    button(type="submit") 
                        span.text Open
            if userLevel === "3" || chat.owner === userId
                form(
                    action=`/chat/delete/${chat.id}`, 
                    method="post", 
                    onsubmit="return confirm('Are you sure you want to delete this chat?');"
                )
                    button(type="submit") 
                        span.text Delete
