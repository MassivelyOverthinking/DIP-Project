doctype html
html(lang="en")
    include templates/head.pug
    include templates/formButton.pug
    +headpage('Register Page', '/style_login.css')
    body
        main.auth-page
            section.auth-card
                .auth-header
                    h1 Create account
                    p Join and get started in a few seconds

                form.auth-form(action="/user/register", method="post")
                    input(type="text", name="username", placeholder="Username", required)
                    input(type="text", name="first_name", placeholder="First name", required)
                    input(type="text", name="last_name", placeholder="Last name", required)
                    input(type="password", name="password", placeholder="Password", required)
                    input(type="password", name="repeat", placeholder="Repeat Password", required)

                    select.dropdown(name="level", required)
                        option(value="0") Select a role
                        option(value="1") User
                        option(value="2") Manager
                        option(value="3") Admin

                    hr.separator
                    +form-button("Create Account")

                    p.footer
                        | Already have an account?
                        a(href="/user/login") Sign in here