doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        link(rel="stylesheet", href="/style_login.css")
        title Create Chat
    body
        main.auth-page
            section.auth-card
                .auth-header
                    h1 Create Chatroom
                    p Create a new chatroom to start chatting

                form.auth-form(action="/chat/create", method="post")
                    input(type="text", name="name", placeholder="Chatroom Name", required)

                    button(type="submit")
                        strong Create Chatroom

                button(type="button") 
                    a(href="/home") Back to Home